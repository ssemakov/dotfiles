;; Host-specific safehouse overrides for ssemakov's machine.
;; Symlinked into ~/.config/agent-safehouse/local-overrides.sb (auto-loaded).

;; --- Network ---
;; 20-network.sb already opens the network. Re-asserting so future tightening
;; of the base profile doesn't silently break agent flows that need outbound
;; HTTPS: rubocop fetching rule packs, gem/npm/cargo/go installs, and the
;; agent's own API calls back to Anthropic/OpenAI/etc.
(allow network*)

;; --- Tool caches (read/write) ---
;; Tools that fetch external resources expect to cache them outside the
;; workdir. Granting RW so first-run downloads succeed instead of crashing
;; mid-lint/mid-install.
(allow file-read* file-write*
  (home-subpath "/.cache")           ;; rubocop, ruff, mypy, pip, claude
  (home-subpath "/Library/Caches")   ;; bundler, ruby-build, generic macOS
  (home-subpath "/.bundle")          ;; bundler config + lock cache
  (home-subpath "/.gem")             ;; rubygems
  (home-subpath "/.npm")             ;; npm
  (home-subpath "/.yarn")            ;; yarn classic
  (home-subpath "/Library/pnpm")     ;; pnpm store
  (home-subpath "/go/pkg/mod")       ;; go modules
  (home-subpath "/.cargo")           ;; cargo registry
  (home-subpath "/.rustup")          ;; rust toolchains
)

;; --- Homebrew (read/write) ---
;; Codex (and other agents) self-update via `brew upgrade --cask`, which writes
;; to /opt/homebrew/var/homebrew/locks/* and the Caskroom. Granting RW so
;; brew-driven self-updates don't error out on the lockfile.
(allow file-read* file-write*
  (subpath "/opt/homebrew")
)

;; --- Tool config (read-only) ---
;; Some tools refuse to start without reading their dotfiles.
(allow file-read*
  (home-literal "/.gemrc")
  (home-literal "/.npmrc")
  (home-literal "/.yarnrc")
  (home-literal "/.yarnrc.yml")
)

;; --- Process listing (pgrep/ps) ---
;; `pgrep` / `ps` query the kernel via sysmond; without this lookup the
;; sandbox returns "sysmond service not found" and Cannot get process list.
;; Used by rails-console / dev-server skills that pgrep for an existing
;; instance before spawning one.
(allow mach-lookup
  (global-name "com.apple.sysmond")
)
(allow sysctl-read)

;; --- System resolver config (read-only) ---
;; Ruby's stdlib `resolv` (loaded transitively by rubocop's
;; Style/IpAddresses cop) opens /etc/resolv.conf at require-time and
;; raises EPERM under the sandbox if it's blocked, killing the process
;; before any lint runs.
(allow file-read*
  (literal "/etc/resolv.conf")
  (literal "/private/etc/resolv.conf")  ;; macOS canonical path
  (literal "/var/run/resolv.conf")      ;; symlink target on macOS
  (literal "/private/var/run/resolv.conf")
  (literal "/etc/hosts")
  (literal "/private/etc/hosts")
  (literal "/etc/services")
  (literal "/private/etc/services")
)
