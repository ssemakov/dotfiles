# Codex config template.
# Copy to ~/.codex/config.toml on a new machine — do NOT symlink:
# codex writes back to this file (project trust, dismissed notices, UX state),
# which would churn the dotfiles repo with machine-specific noise.
#
#   cp ~/workspace/dotfiles/codex/config.toml.template ~/.codex/config.toml
#
# Intentionally omitted (codex will repopulate per host):
#   - model               (don't lock; pick at runtime)
#   - [projects.*]        (per-path trust, machine-specific)
#   - [notice.*]          (acknowledged migration notices)
#   - [tui.model_availability_nux]  (banner counters)

model_reasoning_effort = "medium"
personality = "pragmatic"

[plugins."github@openai-curated"]
enabled = true

# Vim-like navigation in non-text contexts.
# Editor/composer left as-is — modal editing without a mode toggle would
# break typing j/k/etc. as letters.

[tui.keymap.pager]
scroll_down = "j"
scroll_up = "k"
half_page_down = "ctrl-d"
half_page_up = "ctrl-u"
page_down = "ctrl-f"
page_up = "ctrl-b"
jump_top = "g"
jump_bottom = "shift-g"
close = "q"
close_transcript = ["x"]

[tui.keymap.list]
move_down = "j"
move_up = "k"
cancel = "q"

[tui.keymap.approval]
approve = "y"
decline = "n"
deny = "d"
cancel = "esc"
