# Auto-install Ghostty's terminfo on remote hosts over SSH (and fall back to a
# safe TERM if it can't) so tmux/nvim work on boxes that lack xterm-ghostty.
shell-integration-features = cursor,title,ssh-env,ssh-terminfo

theme = TokyoNight Night

# Match iTerm-style true-black background so tmux colors pop
# (set after `theme` so it overrides the theme's background)
background = 000000
